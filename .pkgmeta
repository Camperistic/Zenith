# BigWigs packager config — https://github.com/BigWigsMods/packager
# Packages the Zenith/ folder as the addon for CurseForge / Wago / WoWInterface.
package-as: Zenith

enable-nolib-creation: no

move-folders:
  Zenith: Zenith

ignore:
  - README.md
  - LICENSE
  - .github
  - .pkgmeta
  - tools

manual-changelog:
  filename: Zenith/CHANGELOG.md
  markup-type: markdown
