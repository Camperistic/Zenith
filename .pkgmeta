# BigWigs packager config — https://github.com/BigWigsMods/packager
# Multi-flavour addon at the repo root (Zenith_<Flavor>.toc), packaged as "Zenith".
package-as: Zenith

enable-nolib-creation: no

ignore:
  - tools
  - .github
  - .pkgmeta
  - .gitignore
  # legacy v1.x data — superseded by Data/packs (transformed in Phase 1)
  - Data/Routes
  - Data/Classes
  - Data/Talents
  - Data/Rotations
  - Data/Pets
  - Data/Gear

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown
