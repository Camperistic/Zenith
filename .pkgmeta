# BigWigs packager config — https://github.com/BigWigsMods/packager
# The addon lives at the repo root (Zenith.toc here), packaged as "Zenith".
package-as: Zenith

enable-nolib-creation: no

ignore:
  - tools
  - .github
  - .pkgmeta
  - .gitignore

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown
